# Copy this file to `.env` and fill in the values you need to override.
# Any variable already set in the environment takes precedence over `.env`.

# URL of the zstd-compressed SQLite dump to fetch.
# DATA_URL=https://static.bookwalker.com/data/bkwk-db.sqlite.zst

# Directory used to store the downloaded/extracted database files.
# DATA_DIR=./data

# Address the HTTP server binds to.
# BIND_ADDR=0.0.0.0:8362

# Secret required (via the `X-Refresh-Secret` header) to trigger a manual
# refresh at POST /internal/refresh. Required, no default.
REFRESH_SECRET=change-me
